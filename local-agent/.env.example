# GitHub Personal Access Token — needs repo + read:user scopes
# Can also be stored in AWS SSM Parameter Store (see setup/store_github_token.sh)
GITHUB_TOKEN=your_github_pat_here

# Developer name — determines which skills/DEV_NAME/SKILL.md is loaded
DEV_NAME=sejong

# Disable shell tool confirmation prompt
STRANDS_NON_INTERACTIVE=true

# AgentCore Memory ID (run: uv run setup/create_memory.py)
MEMORY_ID=
